# @TODO: finish replacing the colors here


# Menu
menu.border.color: #fefefa

menu.title.bg: Solid Flat
menu.title.bg.color: #3f356d
menu.title.bg.shadow: 0
menu.title.text.color: #fefefa
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #3f356d
menu.items.text.color: #fefefa
menu.items.disabled.text.color: #cecbd6

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #f78fc1
menu.items.active.text.color: #fefefa

menu.separator.color: #cecbd6
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #3f356d

# Active window
window.active.border.color: #f78fc1


window.active.title.bg: flat solid
window.active.title.bg.color: #3f356d
window.active.title.separator.color: #3f356d
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #fefefa

window.active.handle.bg: flat solid
window.active.handle.bg.color: #3f356d

window.active.grip.bg: flat solid
window.active.grip.bg.color: #3f356d

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #3f356d
window.active.button.unpressed.image.color: #fefefa

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #f78fc1
window.active.button.pressed.image.color: #fefefa

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #3f356d
window.active.button.disabled.image.color: #cecbd6

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #3f356d
window.active.button.hover.image.color: #f78fc1

#window.active.button.toggled.bg: #f78fc1
#window.active.button.toggled.image.color: #fefefa

# Inactive window
window.inactive.border.color: #fefefa

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #3f356d
window.inactive.title.separator.color: #3f356d
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #cecbd6

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #3f356d

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #3f356d

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #3f356d
window.inactive.button.unpressed.image.color: #cecbd6

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #f78fc1
window.inactive.button.pressed.image.color: #fefefa

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #cecbd6
window.inactive.button.disabled.image.color: #3f356d

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #3f356d
window.inactive.button.hover.image.color: #f78fc1


# OSD
osd.border.width: 1
osd.border.color: #f78fc1

osd.bg: flat solid
osd.bg.color: #3f356d
osd.label.bg: flat solid
osd.label.bg.color: #3f356d
osd.label.text.color: #fefefa

# OSD
osd.bg: Solid Flat
osd.bg.color: #3f356d
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #f78fc1
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #221c4f

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #3f356d
#osd.button.unpressed.*.border.color: #fefefa

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #f78fc1
#osd.button.pressed.*.border.color: #fefefa

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #fefefa
#osd.button.focused.*.border.color: #221c4f

osd.button.focused.box.color: #f78fc1


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 3
padding.width: 8
padding.height: 3
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
